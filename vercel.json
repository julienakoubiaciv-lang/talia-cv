{
  "version": 2,
  "name": "talia-dashboard",
  "builds": [
    { "src": "talia-app.html", "use": "@vercel/static" },
    { "src": "talia-generateur.html", "use": "@vercel/static" },
    { "src": "talia-dashboard.html", "use": "@vercel/static" },
    { "src": "portail-candidat.html", "use": "@vercel/static" },
    { "src": "inscription-candidat.html", "use": "@vercel/static" },
    { "src": "supabase-schema.sql", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/", "dest": "/talia-app.html" },
    { "src": "/generateur", "dest": "/talia-generateur.html" },
    { "src": "/dashboard", "dest": "/talia-dashboard.html" },
    { "src": "/portail", "dest": "/portail-candidat.html" },
    { "src": "/inscription", "dest": "/inscription-candidat.html" },
    { "src": "/(.*)", "dest": "/$1" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Content-Security-Policy", "value": "default-src 'self' 'unsafe-inline' 'unsafe-eval' https:; img-src 'self' data: https: blob:; font-src 'self' https://fonts.gstatic.com;" }
      ]
    }
  ]
}
