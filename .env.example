# Copier ce fichier en .env.local pour le développement local
# Ne JAMAIS committer .env.local (déjà dans .gitignore)

# ── Anthropic ─────────────────────────────────────────────────
# La clé Anthropic vit UNIQUEMENT côté serveur, dans les secrets de
# l'Edge Function Supabase `claude-proxy` (jamais dans le bundle client).
# À définir dans : Supabase → Project → Edge Functions → Secrets
#   ANTHROPIC_API_KEY=sk-ant-...

# ── Supabase ──────────────────────────────────────────────────
VITE_SUPABASE_URL=https://VOTRE_PROJET.supabase.co
VITE_SUPABASE_ANON_KEY=votre_anon_key_ici

# ── Vérification téléphone (OTP SMS) — activer plus tard ──────
VITE_REQUIRE_PHONE_VERIFICATION=false
