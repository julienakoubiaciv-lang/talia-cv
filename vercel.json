{
  "regions": [
    "cdg1"
  ],
  "functions": {
    "api/anthropic.js": {
      "maxDuration": 30
    },
    "api/pdf.js": {
      "maxDuration": 60,
      "memory": 1024
    },
    "api/parse-pdf.js": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/((?!api/|metier/|guides-metiers).*)",
      "destination": "/index.html"
    }
  ],
  "cleanUrls": true
}
